<%- include('includes/head.ejs') %>

<%- include('includes/navigation.ejs') %>

        <main class="container">
      <div class="shop-layout">
        <!-- Sidebar Filters -->
        <aside class="shop-sidebar">
          <div class="sidebar-section">
            <h4>Categories</h4>
            <ul class="filter-list">
              <li><a href="#" class="active">All Products</a></li>
              <li><a href="#">Living Room</a></li>
              <li><a href="#">Bedroom</a></li>
              <li><a href="#">Office</a></li>
              <li><a href="#">Dining</a></li>
              <li><a href="#">Outdoor</a></li>
            </ul>
          </div>

          <div class="sidebar-section">
            <h4>Price Range</h4>
            <div class="price-range">
              <input
                type="number"
                placeholder="Min"
                name="price_min"
                aria-label="Minimum price"
              />
              <span>—</span>
              <input
                type="number"
                placeholder="Max"
                name="price_max"
                aria-label="Maximum price"
              />
            </div>
          </div>

          <div class="sidebar-section">
            <h4>Material</h4>
            <ul class="filter-list">
              <li><a href="#">Oak</a></li>
              <li><a href="#">Walnut</a></li>
              <li><a href="#">Maple</a></li>
              <li><a href="#">Fabric</a></li>
              <li><a href="#">Leather</a></li>
            </ul>
          </div>
        </aside>

        <!-- Product Grid -->
        <section>
          <div class="flex justify-between items-center mb-3">
            <p class="text-muted" style="margin: 0">
              Showing <strong>12</strong> products
            </p>
          </div>

          <div class="product-grid">
            <% if(products.length > 0) { %>
                <% for (let product of products) { %>
                <!-- Product Card 1 -->
                <article class="product-card">
                <div class="product-img">
                    <img
                    src="https://images.unsplash.com/photo-1567538096630-e0c55bd6374c?w=520&h=440&fit=crop"
                    alt="Oslo Lounge Chair"
                    />
                </div>
                <div class="product-info">
                    <p class="product-category">Living Room</p>
                    <h3 class="product-title"><%= product.title %></h3>
                    <p class="product-price">$849.00</p>
                    <form method="POST" action="/cart/add">
                    <input type="hidden" name="product_id" value="1" />
                    <button type="submit" class="btn btn-primary btn-block">
                        Add to Cart
                    </button>
                    </form>
                </div>
                </article>
                 <% } %>
            <% } else { %>
                <h1> No Product</h1>
                <% } %>
          </div>

          <!-- Pagination -->
          <nav class="pagination" aria-label="Shop pagination">
            <a href="#">&laquo;</a>
            <span class="active">1</span>
            <a href="#">2</a>
            <a href="#">3</a>
            <a href="#">&raquo;</a>
          </nav>
        </section>
      </div>
    </main>

<%- include('includes/end.ejs') %>